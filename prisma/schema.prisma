// This file configures the initialization of Prisma Client on the server.
// The framework you're using might have its own way of handling this.
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SystemRole {
  OWNER
  ADMIN
  MEMBER
}

// ==========================================
// MULTI-TENANT FOUNDATION
// ==========================================

model Account {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  clients       Client[]
  posts         Post[]
  notifications Notification[]
  portfolios    Portfolio[]
  roles         AgencyRole[]
  invitations   Invitation[]

  @@map("accounts")
}

model User {
  id           String   @id @default(cuid())
  accountId    String?  @map("account_id") // null para superadmins (acima dos tenants)
  email        String   @unique
  name         String
  phone        String?
  role         SystemRole @default(MEMBER) // Papel base no sistema
  authId             String?  @unique @map("auth_id") // Supabase Auth UID
  isSuperAdmin       Boolean  @default(false) @map("is_super_admin")
  emailNotifications         Boolean  @default(true) @map("email_notifications")
  notifyEmailClientComment   Boolean  @default(true) @map("notify_email_client_comment")
  notifyEmailInternalComment Boolean  @default(true) @map("notify_email_internal_comment")
  notifyEmailStatusChange    Boolean  @default(true) @map("notify_email_status_change")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  account      Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdPosts Post[]        @relation("PostCreatedBy")
  updatedPosts Post[]        @relation("PostUpdatedBy")
  comments     Comment[]
  postVersions PostVersion[]
  notifications Notification[] @relation("UserNotifications")
  
  // Novas relações para Agência
  userRoles    UserRoleMapping[]
  access       UserAccess[]

  @@map("users")
}

// Tabela de junção para Cargos Customizados (Múltiplos cargos por usuário)
model UserRoleMapping {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  roleId    String @map("role_id")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AgencyRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role_mappings")
}

model AgencyRole {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  name      String   // Ex: "Designer", "Social Media Pleno"
  createdAt DateTime @default(now()) @map("created_at")
  
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  users   UserRoleMapping[]

  @@map("agency_roles")
}

// ==========================================
// DOMAIN ENTITIES
// ==========================================

model Client {
  id                  String   @id @default(cuid())
  accountId           String   @map("account_id")
  portfolioId         String?  @map("portfolio_id")
  name                String
  brandColor          String   @map("brand_color")
  brandColorSecondary String?  @map("brand_color_secondary")
  logoUrl             String?  @map("logo_url")
  logoInitials        String   @map("logo_initials")
  industry            String?
  instagramHandle     String?  @map("instagram_handle")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio Portfolio?   @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  posts     Post[]
  access    UserAccess[]

  @@map("clients")
}

model Portfolio {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  name      String   // Ex: "Carteira Varejo"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clients Client[]
  access  UserAccess[]

  @@map("portfolios")
}

enum PermissionLevel {
  VIEW
  EDIT
  DELETE
  ADMIN
}

model UserAccess {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  clientId    String?         @map("client_id")
  portfolioId String?         @map("portfolio_id")
  level       PermissionLevel @default(VIEW)
  createdAt   DateTime        @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("user_access")
}

model Post {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  clientId      String   @map("client_id")
  title         String
  description   String   @default("")
  type          String // PostType: feed | reels | stories | carrossel | tiktok | youtube | linkedin | twitter
  status        String   @default("rascunho") // PostStatus: rascunho | em_producao | pronto | publicado | cancelado
  dayOfWeek     String   @map("day_of_week") // DayOfWeek: seg | ter | qua | qui | sex | sab | dom
  scheduledDate String?  @map("scheduled_date") // ISO date string YYYY-MM-DD
  scheduledTime String?  @map("scheduled_time") // HH:MM
  driveLink     String?  @map("drive_link")
  caption       String?
  hashtags      String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")
  updatedById   String?  @map("updated_by_id")

  account    Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy  User?         @relation("PostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?         @relation("PostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  shareLinks ShareLink[]
  comments   Comment[]
  versions   PostVersion[]

  @@map("posts")
}

// ==========================================
// COLLABORATION FEATURES (PRO)
// ==========================================

/// MVP: guarda apenas 1 snapshot por post (o estado ANTES da última edição).
/// Permite "desfazer" a última alteração com um clique.
model PostVersion {
  id          String   @id @default(cuid())
  postId      String   @map("post_id")
  /// JSON com o estado completo do post no momento da captura
  snapshot    String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id")

  post      Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([postId]) // Garante máximo 1 versão por post
  @@map("post_versions")
}

model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid()) // Token único para a URL pública
  postId       String    @map("post_id")
  expiresAt    DateTime? @map("expires_at")
  allowComments Boolean  @default(false) @map("allow_comments")
  createdAt    DateTime  @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("share_links")
}

model Invitation {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  email     String
  token     String   @unique @default(cuid())
  roleName  String?  @map("role_name") // Nome do cargo sugerido
  accepted  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Comment {
  id         String   @id @default(cuid())
  postId     String   @map("post_id")
  content    String   @db.Text
  isInternal  Boolean  @default(false) @map("is_internal") // Se true, só a equipe vê
  authorId    String?  @map("author_id")
  authorName  String?  @map("author_name") // Para clientes anônimos via ShareLink
  authorEmail String?  @map("author_email") // E-mail obrigatório ou opcional do cliente
  createdAt   DateTime @default(now()) @map("created_at")

  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@map("comments")
}

// ==========================================
// SYSTEM NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  accountId String   @map("account_id") // Para isolamento multi-tenant
  userId    String   @map("user_id")    // Destinatário da Notificação
  type      String   // Ex: "NEW_COMMENT", "POST_APPROVED"
  title     String
  message   String   @db.Text
  linkUrl   String?  @map("link_url")   // Rota para redicionamento ao click
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, read]) // Permite listar a contagem de não-lidas bem rápido no painel
  @@map("notifications")
}
